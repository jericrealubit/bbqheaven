{
  "name": "bbqheaven",
  "compatibility_date": "2025-09-27",
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
  },
  // Add this section to exclude the heavy folders
  "upload": {
    "dir": ".",
    "ignore_dotfiles": false,
    "include": [
      "*.html",
      "*.css",
      "*.js",
      "images/**/*",
      "data/**/*",
      "env.js",
    ],
    "exclude": [
      "node_modules",
      "package-lock.json",
      "package.json",
      "generate-env.js",
    ],
  },
}
